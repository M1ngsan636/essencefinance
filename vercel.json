{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "@vercel/php@0.6.0"
    },
    {
      "src": "api/*.php",
      "use": "@vercel/php@0.6.0"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}