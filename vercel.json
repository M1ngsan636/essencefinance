{
  "version": 2,
  "builds": [
    {
      "src": "index.php",
      "use": "@vercel/php@0.6.0"
    },
    {
      "src": "add_transaction.php",
      "use": "@vercel/php@0.6.0"
    }
  ],
  "routes": [
    {
      "src": "/add_transaction",
      "dest": "/add_transaction.php"
    },
    {
      "src": "/",
      "dest": "/index.php"
    }
  ]
}